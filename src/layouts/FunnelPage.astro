---
// MCA Funnel Page Layout — matches yournextfund.com branding
// — Max

const { page } = Astro.props;
const { industry, city, funding, title, metaDesc, h1, faqSection, stats } = page;

// Lead form endpoint — posts to your existing apply flow
const APPLY_URL = 'https://yournextfund.com/api/apply';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={metaDesc} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`https://funding.yournextfund.com/${page.slug}/`} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:url" href={`https://funding.yournextfund.com/${page.slug}/`} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="YourNextFund" />

  <!-- Schema.org: FinancialService + LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FinancialService',
    name: title,
    description: metaDesc,
    provider: {
      '@type': 'Organization',
      name: 'YourNextFund',
      url: 'https://funding.yournextfund.com',
      telephone: '+1-800-000-0000'
    },
    areaServed: {
      '@type': 'City',
      name: city.name,
      addressRegion: city.state
    },
    serviceType: funding.name,
    audience: {
      '@type': 'BusinessAudience',
      name: industry.name
    }
  })} />

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqSection.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: f.a
      }
    }))
  })} />

  <!-- Google Site Verification - replace with your code -->
  <!-- <meta name="google-site-verification" content="REPLACE_WITH_YOUR_CODE" /> -->

  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #0a0a0a; background: #ffffff; line-height: 1.6; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
    a { color: #0066ff; text-decoration: none; }

    /* Header */
    header { background: #0a0a0a; padding: 16px 0; }
    .header-inner { display: flex; justify-content: space-between; align-items: center; max-width: 1100px; margin: 0 auto; padding: 0 20px; }
    .logo { color: #fff; font-size: 20px; font-weight: 700; letter-spacing: -0.5px; }
    .logo span { color: #0066ff; }
    .nav-link { color: rgba(255,255,255,0.7); font-size: 14px; font-weight: 500; }
    .nav-link:hover { color: #fff; }

    /* Hero */
    .hero { background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%); color: #fff; padding: 60px 0 40px; }
    .hero h1 { font-size: clamp(24px, 4vw, 40px); font-weight: 800; letter-spacing: -1px; max-width: 700px; }
    .hero p { margin-top: 16px; font-size: 18px; color: rgba(255,255,255,0.8); max-width: 600px; }
    .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(0,102,255,0.15); border: 1px solid rgba(0,102,255,0.3); padding: 6px 14px; border-radius: 100px; font-size: 13px; color: #4d9fff; margin-bottom: 20px; }
    .hero-stats { display: flex; flex-wrap: wrap; gap: 32px; margin-top: 32px; }
    .hero-stat { text-align: left; }
    .hero-stat .num { font-size: 28px; font-weight: 800; color: #fff; }
    .hero-stat .label { font-size: 13px; color: rgba(255,255,255,0.6); margin-top: 2px; }

    /* Lead Form */
    .lead-form-wrap { background: #fff; border-radius: 16px; padding: 28px; box-shadow: 0 8px 32px rgba(0,0,0,0.3); margin-top: 32px; max-width: 480px; }
    .lead-form-wrap h3 { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
    .lead-form-wrap p.sub { font-size: 14px; color: #666; margin-bottom: 20px; }
    .form-row { margin-bottom: 14px; }
    .form-row input, .form-row select { width: 100%; padding: 12px 14px; border: 1px solid #e0e0e0; border-radius: 8px; font-size: 15px; transition: border 0.2s; }
    .form-row input:focus, .form-row select:focus { outline: none; border-color: #0066ff; }
    .btn-submit { width: 100%; padding: 14px; background: #0066ff; color: #fff; border: none; border-radius: 8px; font-size: 16px; font-weight: 700; cursor: pointer; transition: background 0.2s; }
    .btn-submit:hover { background: #0052cc; }
    .trust-line { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #666; margin-top: 12px; }

    /* Content sections */
    .section { padding: 48px 0; }
    .section h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 800; letter-spacing: -0.5px; margin-bottom: 16px; }
    .section p { font-size: 16px; color: #444; margin-bottom: 14px; }

    /* Funding cards */
    .funding-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 24px; }
    .funding-card { background: #f8f9fa; border: 1px solid #e8e8e8; border-radius: 12px; padding: 20px; transition: border 0.2s; }
    .funding-card:hover { border-color: #0066ff; }
    .funding-card .icon { font-size: 28px; margin-bottom: 8px; }
    .funding-card h4 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
    .funding-card p { font-size: 14px; color: #666; margin-bottom: 0; }
    .funding-card .best-for { font-size: 12px; color: #0066ff; margin-top: 8px; font-weight: 600; }

    /* FAQ */
    .faq-item { border-bottom: 1px solid #e8e8e8; padding: 20px 0; }
    .faq-item h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; cursor: pointer; }
    .faq-item p { font-size: 15px; color: #555; }

    /* Trust badges */
    .trust-badges { display: flex; flex-wrap: wrap; gap: 24px; margin-top: 24px; }
    .trust-badge { display: flex; align-items: center; gap: 10px; }
    .trust-badge .icon { font-size: 24px; }
    .trust-badge .text { font-size: 14px; color: #444; }
    .trust-badge .text strong { display: block; font-weight: 700; color: #0a0a0a; }

    /* CTA banner */
    .cta-banner { background: linear-gradient(135deg, #0066ff 0%, #0044cc 100%); color: #fff; padding: 48px 0; text-align: center; }
    .cta-banner h2 { color: #fff; margin-bottom: 12px; }
    .cta-banner p { color: rgba(255,255,255,0.9); margin-bottom: 24px; }
    .cta-banner .btn { display: inline-block; background: #fff; color: #0066ff; padding: 14px 32px; border-radius: 8px; font-size: 16px; font-weight: 700; }

    /* Footer */
    footer { background: #0a0a0a; color: rgba(255,255,255,0.6); padding: 40px 0; }
    .footer-inner { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
    .footer-links { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 16px; }
    .footer-links a { color: rgba(255,255,255,0.6); font-size: 14px; }
    .footer-links a:hover { color: #fff; }
    .footer-disclaimer { margin-top: 20px; font-size: 12px; color: rgba(255,255,255,0.4); }

    @media (max-width: 768px) {
      .hero { padding: 40px 0 30px; }
      .lead-form-wrap { max-width: 100%; }
      .hero-stats { gap: 20px; }
      .section { padding: 32px 0; }
    }
  </style>
</head>
<body>

  <!-- Header -->
  <header>
    <div class="header-inner">
      <a href="https://funding.yournextfund.com" class="logo">Your<span>Next</span>Fund</a>
      <a href="https://yournextfund.com/apply" class="nav-link">Apply →</a>
    </div>
  </header>

  <!-- Hero with Lead Form -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">
        <span>⚡</span>
        <span>Funding in as little as 24 hours</span>
      </div>
      <h1>{h1}</h1>
      <p>
        Apply once and our AI shops 100+ funders to find the best {funding.name.toLowerCase()} offer
        for your {industry.name.toLowerCase()} in {city.name}, {city.state}.
        No hard credit pull. No paperwork chase.
      </p>

      <div class="hero-stats">
        <div class="hero-stat">
          <div class="num">100+</div>
          <div class="label">Funding partners</div>
        </div>
        <div class="hero-stat">
          <div class="num">24/7</div>
          <div class="label">AI works your file</div>
        </div>
        <div class="hero-stat">
          <div class="num">$2M+</div>
          <div class="label">Funding available</div>
        </div>
        <div class="hero-stat">
          <div class="num">{stats.businesses}</div>
          <div class="label">Small businesses in {city.name}</div>
        </div>
      </div>

      <!-- Lead Capture Form -->
      <div class="lead-form-wrap">
        <h3>See your offers — 60 seconds</h3>
        <p class="sub">No hard credit pull. No obligation.</p>
        <form action={APPLY_URL} method="POST" id="lead-form">
          <input type="hidden" name="source_page" value={page.slug} />
          <input type="hidden" name="industry" value={industry.name} />
          <input type="hidden" name="city" value={`${city.name}, ${city.state}`} />
          <input type="hidden" name="funding_type" value={funding.name} />
          <input type="hidden" name="lead_type" value="programmatic_seo" />

          <div class="form-row">
            <input type="text" name="business_name" placeholder="Business name" required />
          </div>
          <div class="form-row">
            <input type="text" name="full_name" placeholder="Your name" required />
          </div>
          <div class="form-row">
            <input type="email" name="email" placeholder="Email address" required />
          </div>
          <div class="form-row">
            <input type="tel" name="phone" placeholder="Phone number" required />
          </div>
          <div class="form-row">
            <select name="funding_amount" required>
              <option value="">How much do you need?</option>
              <option value="5000-25000">$5K - $25K</option>
              <option value="25000-100000">$25K - $100K</option>
              <option value="100000-500000">$100K - $500K</option>
              <option value="500000+">$500K+</option>
            </select>
          </div>
          <div class="form-row">
            <select name="time_in_business" required>
              <option value="">Time in business</option>
              <option value="0-6">Less than 6 months</option>
              <option value="6-12">6-12 months</option>
              <option value="12-24">1-2 years</option>
              <option value="24+">2+ years</option>
            </select>
          </div>
          <button type="submit" class="btn-submit">Get my best offer →</button>
          <div class="trust-line">
            <span>🔒</span>
            <span>Bank-level encryption. Your data is never sold.</span>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Industry Content -->
  <section class="section">
    <div class="container">
      <h2>{funding.name} for {industry.name} in {city.name}</h2>
      <p>{industry.blurb}</p>
      <p>
        {city.name} is home to {stats.businesses} small businesses, and {industry.name.toLowerCase()} are a driving force
        in the local economy. Whether you're on {" "} {city.name === 'New York' ? '5th Avenue' : `Main Street`}
        or expanding across the {city.state} metro, access to fast capital can make the difference between
        seizing an opportunity and watching it pass.
      </p>
      <p>
        Our AI-powered platform shops your file to 100+ funders simultaneously — including
        those who specialize in {industry.name.toLowerCase()}. That means more offers, better terms,
        and funding in as little as 24 hours. One application. Zero paperwork chase.
      </p>
    </div>
  </section>

  <!-- Funding Options -->
  <section class="section" style="background:#f8f9fa;">
    <div class="container">
      <h2>Funding options for {industry.name.toLowerCase()}</h2>
      <p>One application. Every kind of funding. Our AI figures out what fits your business best.</p>
      <div class="funding-grid">
        <div class="funding-card" style={funding.slug === 'mca' ? 'border-color:#0066ff;' : ''}>
          <div class="icon">⚡</div>
          <h4>Merchant Cash Advance</h4>
          <p>Funding based on your revenue, not just credit. Repayment follows your sales.</p>
          <div class="best-for">Best for: Steady card sales</div>
        </div>
        <div class="funding-card" style={funding.slug === 'working-capital' ? 'border-color:#0066ff;' : ''}>
          <div class="icon">📈</div>
          <h4>Working Capital</h4>
          <p>Cover payroll, inventory, and operations. Funded in 24 hours.</p>
          <div class="best-for">Best for: Cash flow gaps</div>
        </div>
        <div class="funding-card" style={funding.slug === 'line-of-credit' ? 'border-color:#0066ff;' : ''}>
          <div class="icon">💳</div>
          <h4>Line of Credit</h4>
          <p>Draw as you need it. Only pay for what you use.</p>
          <div class="best-for">Best for: Flexible access</div>
        </div>
        <div class="funding-card" style={funding.slug === 'short-term-loan' ? 'border-color:#0066ff;' : ''}>
          <div class="icon">💰</div>
          <h4>Short-Term Loan</h4>
          <p>Fast lump-sum funding with clear, fixed terms.</p>
          <div class="best-for">Best for: One-time needs</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section">
    <div class="container">
      <h2>Why {industry.name.toLowerCase()} in {city.name} choose us</h2>
      <div class="trust-badges">
        <div class="trust-badge">
          <span class="icon">🔒</span>
          <div class="text">
            <strong>Bank-level security</strong>
            Encrypted end to end. Never sold.
          </div>
        </div>
        <div class="trust-badge">
          <span class="icon">⚡</span>
          <div class="text">
            <strong>Decisions in 24 hours</strong>
            AI works your file instantly.
          </div>
        </div>
        <div class="trust-badge">
          <span class="icon">🤝</span>
          <div class="text">
            <strong>Real advisors, always</strong>
            AI does the work, humans answer the phone.
          </div>
        </div>
        <div class="trust-badge">
          <span class="icon">🎯</span>
          <div class="text">
            <strong>100+ funders compared</strong>
            We shop, you choose.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background:#f8f9fa;">
    <div class="container">
      <h2>Frequently asked questions</h2>
      {faqSection.map(faq => (
        <div class="faq-item">
          <h3>{faq.q}</h3>
          <p>{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="container">
      <h2>Stop chasing lenders. Let your AI do it.</h2>
      <p>Upload once and get your best offer — no hard credit pull, no obligation.</p>
      <a href={APPLY_URL} class="btn">Get my best offer →</a>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-inner">
      <div class="logo">Your<span style="color:#0066ff">Next</span>Fund</div>
      <p style="margin-top:8px; font-size:14px;">The first AI-powered funding desk.</p>
      <div class="footer-links">
        <a href="https://funding.yournextfund.com">Home</a>
        <a href="https://yournextfund.com/apply">Apply</a>
        <a href={`https://funding.yournextfund.com/${industry.slug}-mca-${city.slug}/`}>MCA for {industry.name} in {city.name}</a>
        <a href={`https://funding.yournextfund.com/${industry.slug}-working-capital-${city.slug}/`}>Working Capital for {industry.name} in {city.name}</a>
        <a href={`https://funding.yournextfund.com/${industry.slug}-line-of-credit-${city.slug}/`}>Line of Credit for {industry.name} in {city.name}</a>
      </div>
      <p class="footer-disclaimer">
        © 2026 YourNextFund. All rights reserved. Funding subject to approval. Not available in all states.
        This is not a loan offer. Merchant Cash Advances are based on future revenue, not credit scores.
      </p>
    </div>
  </footer>

  <!-- Google Ads + Analytics conversion tracking — Max -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18319278108"></script>
  <script set:html={`
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-18319278108', {
      page_path: '/${page.slug}/',
      page_title: ${JSON.stringify(title)}
    });

    // Form submit tracking — sends conversion to Google Ads
    document.getElementById('lead-form')?.addEventListener('submit', function(e) {
      gtag('event', 'conversion', {
        'send_to': 'AW-18319278108/LEAD_FORM',
        'value': 50.0,
        'currency': 'USD',
        'transaction_id': '${page.slug}_' + Date.now()
      });
      gtag('event', 'generate_lead', {
        event_category: 'form_submit',
        event_label: '${page.slug}',
        value: 1
      });
    });
  `} />

</body>
</html>